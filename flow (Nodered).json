    {
        "id": "527a4e0ccf1b9178",
        "type": "function",
        "z": "42724ec9b7f2ae5f",
        "name": "function to sql",
        "func": "var p = msg.payload;\n\n// Debug each field type\nnode.warn(\"Log_Timestamp type: \" + typeof p.Log_Timestamp);\nnode.warn(\"Occupancy type: \" + typeof p.Occupancy);\nnode.warn(\"Temperature_Data type: \" + typeof p.Temperature_Data);\nnode.warn(\"Humidity_Data type: \" + typeof p.Humidity_Data);\nnode.warn(\"Pressure_Data type: \" + typeof p.Pressure_Data);\nnode.warn(\"Dust_Data type: \" + typeof p.Dust_Data);\nnode.warn(\"Light_Data type: \" + typeof p.Light_Data);\nnode.warn(\"Distance_Data type: \" + typeof p.Distance_Data);\nnode.warn(\"Fan_State type: \" + typeof p.Fan_State);\n\n// Build SQL statement with fallback values\nvar sqlStmt =\n    \"INSERT INTO ALL_SENS_DATA (\" +\n    \"Log_Timestamp, Occupancy, Temperature_Data, Humidity_Data, Pressure_Data, \" +\n    \"Dust_Data, Light_Data, Distance_Data, Fan_State\" +\n    \") VALUES (\" +\n    (p.Log_Timestamp || 0) + \", \" +\n    (p.Occupancy || 0) + \", \" +\n    (p.Temperature_Data || 0) + \", \" +\n    (p.Humidity_Data || 0) + \", \" +\n    (p.Pressure_Data || 0) + \", \" +\n    (p.Dust_Data || 0) + \", \" +\n    (p.Light_Data || 0) + \", \" +\n    (p.Distance_Data || 0) + \", \" +\n    (p.Fan_State || 0) +\n    \");\";\n\n// Pass SQL to the SQLite node\nmsg.topic = sqlStmt;\nreturn msg;\n\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
