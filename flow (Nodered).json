        "name": "Function To Thingspeak",
        "func": "var p = msg.payload;\n\nvar apiKey = \"E9JLAZ1WMPW7G7CL\";   \n\nmsg.url =\n    \"https://api.thingspeak.com/update?api_key=\" + apiKey +\n    \"&field1=\" + p.Occupancy +\n    \"&field2=\" + p.Temperature_Data +\n    \"&field3=\" + p.Humidity_Data +\n    \"&field4=\" + p.Pressure_Data +\n    \"&field5=\" + p.Dust_Data +\n    \"&field6=\" + p.Light_Data +\n    \"&field7=\" + p.Distance_Data +\n    \"&field8=\" + p.Fan_State;\n\nreturn msg;\n\n",
