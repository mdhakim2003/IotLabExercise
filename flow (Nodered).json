    {
        "id": "6fe11c635b7a7bc0",
        "type": "function",
        "z": "42724ec9b7f2ae5f",
        "name": "function 8 Data to table",
        "func": "var p = msg.payload;\n\nvar occupancy = [];\nvar temperature = [];\nvar humidity = [];\nvar pressure = [];\nvar dust = [];\nvar light = [];\nvar distance = [];\nvar fan = [];\n\nfor (var i = 0; i < p.length; i++) {\n    var timestamp = p[i].log_data_timestamp;\n\n    occupancy.push({ x: timestamp, y: p[i].Occupancy });\n    temperature.push({ x: timestamp, y: p[i].Temperature_Data });\n    humidity.push({ x: timestamp, y: p[i].Humidity_Data });\n    pressure.push({ x: timestamp, y: p[i].Pressure_Data });\n    dust.push({ x: timestamp, y: p[i].Dust_Data });\n    light.push({ x: timestamp, y: p[i].Light_Data });\n    distance.push({ x: timestamp, y: p[i].Distance_Data });\n    fan.push({ x: timestamp, y: p[i].Fan_State });\n}\n\nfunction format(seriesName, label, data) {\n    return [{\n        series: [seriesName],\n        labels: [label],\n        data: [data]\n    }];\n}\n\nreturn [\n    { payload: format(\"log date\", \"Occupancy\", occupancy) },\n    { payload: format(\"log date\", \"Temperature\", temperature) },\n    { payload: format(\"log date\", \"Humidity\", humidity) },\n    { payload: format(\"log date\", \"Pressure\", pressure) },\n    { payload: format(\"log date\", \"Dust\", dust) },\n    { payload: format(\"log date\", \"Light\", light) },\n    { payload: format(\"log date\", \"Distance\", distance) },\n    { payload: format(\"log date\", \"Fan State\", fan) }\n];",
        "outputs": 8,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
